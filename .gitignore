# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/
/build
/app/build

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/deploymentTargetSelector.xml
.idea/deviceManager.xml
.idea/runConfigurations.xml
.idea/studiobot.xml

# Keystore files (keep signing keys secure!)
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (Contains API keys - DO NOT COMMIT)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Kotlin
.kotlin/

# Mac OS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Misc
*.swp
*~
.env
.env.local

# Release builds (APKs should be in releases, not tracked)
app/release/*.apk
!app/release/output-metadata.json

# Baseline profiles (generated, can be large)
app/release/baselineProfiles/

# Claude Code memory (personal notes)
.claude/

# Sensitive/Personal data
*.sqlite
*.db
credentials.json
secrets.json
